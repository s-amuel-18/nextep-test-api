# ── Servidor ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de Datos ─────────────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bookstore?schema=public

# ── API Externa de Tasas de Cambio ────────────────────────────────
# Tasa usada como fallback si la API de exchangerate-api.com no responde
DEFAULT_EXCHANGE_RATE=1.0

# Moneda usada si el supplier_country del libro no tiene mapeo en currency.map.ts
DEFAULT_CURRENCY=USD

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
